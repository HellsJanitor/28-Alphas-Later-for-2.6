<configs>
    <!-- Make player dropped bags bigger to accomodate new size-->
	<set xpath="/lootcontainers/lootcontainer[@name='playerBackpack']/@size">10,10</set>

	<append xpath="/lootcontainers/lootgroup[@name='groupT1Clothing']">
		<item name="backpackUpgradeTier1" loot_prob_template="low"/>
	</append>
	
	<append xpath="/lootcontainers/lootgroup[@name='groupT2Clothing']">
		<item name="backpackUpgradeTier2" loot_prob_template="low"/>
	</append>
	
	<append xpath="/lootcontainers/lootgroup[@name='groupT3Clothing']">
		<item name="backpackUpgradeTier3" loot_prob_template="veryLow"/>
	</append>
	
	<append xpath="/lootcontainers/lootgroup[@name='modArmorT1']">
		<item name="backpackUpgradeTier1"/>
	</append>
	
	<append xpath="/lootcontainers/lootgroup[@name='modArmorT2']">
		<item name="backpackUpgradeTier2"/>
	</append>
	
	<append xpath="/lootcontainers/lootgroup[@name='modArmorT3']">
		<item name="backpackUpgradeTier3"/>
	</append>
</configs>