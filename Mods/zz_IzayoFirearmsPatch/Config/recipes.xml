<HellsJanitor>
	
	<conditional>
		<if cond="mod_loaded('IZY_RMP_45ACP')">
			<append xpath="/recipes">
				<!-- bundles -->
				<recipe name="ammoBundle45ACPBulletBall" count="1" craft_time="240" craft_area="workbench" tags="learnable,workbenchCrafting">
					<ingredient name="ammo45ACPBulletBall" count="100"/>
				</recipe>
	
				<recipe name="ammoBundle45ACPHighpower" count="1" craft_time="360" craft_area="workbench" tags="learnable,workbenchCrafting">
					<ingredient name="ammo45ACPHighpower" count="100"/>
				</recipe>
	
				<recipe name="ammoBundle45ACPArmorpiecing" count="1" craft_time="360" craft_area="workbench" tags="learnable,workbenchCrafting">
					<ingredient name="ammo45ACPArmorpiecing" count="100"/>
				</recipe>
				
				<recipe name="ammoBundle45ACPEnhanced" count="1" craft_time="360" craft_area="workbench" tags="learnable,workbenchCrafting">
					<ingredient name="ammo45ACPEnhanced" count="100"/>
				</recipe>
				
				<!-- dismantling -->
				<recipe name="ammoDismantle45ACPBulletBall" count="1" craft_area="workbench" tags="workbenchCrafting" craft_tool="toolAmmoPress">
					<ingredient name="ammo45ACPBulletBall" count="10"/>
				</recipe>
			
				<recipe name="ammoDismantle45ACPHighpower" count="1" craft_area="workbench" tags="workbenchCrafting" craft_tool="toolAmmoPress">
					<ingredient name="ammo45ACPHighpower" count="10"/>
				</recipe>
			
				<recipe name="ammoDismantle45ACPArmorpiecing" count="1" craft_area="workbench" tags="workbenchCrafting" craft_tool="toolAmmoPress">
					<ingredient name="ammo45ACPArmorpiecing" count="10"/>
				</recipe>
			</append>
		</if>
	</conditional>
	
	<conditional>
		<if cond="mod_loaded('IZY_RMP_556pack')">
			<append xpath="/recipes">
			<!-- Bundes -->
				<recipe name="ammo556mmBulletBallBundle" count="1" craft_time="240" craft_area="workbench" tags="learnable,workbenchCrafting">
					<ingredient name="ammo556mmBulletBall" count="100"/>
				</recipe>
	
				<recipe name="ammo556mmHIpowerBundle" count="1" craft_time="360" craft_area="workbench" tags="learnable,workbenchCrafting">
					<ingredient name="ammo556mmHIpower" count="100"/>
				</recipe>
	
				<recipe name="ammo556mmArmorPiercingBundle" count="1" craft_time="360" craft_area="workbench" tags="learnable,workbenchCrafting">
					<ingredient name="ammo556mmArmorPiercing" count="100"/>
				</recipe>
				<!-- Dismantling -->
				<recipe name="ammoDismantle556mmBulletBall" count="1" craft_area="workbench" tags="workbenchCrafting" craft_tool="toolAmmoPress">
					<ingredient name="ammo556mmBulletBall" count="10"/>
				</recipe>
			
				<recipe name="ammoDismantle556mmHIpower" count="1" craft_area="workbench" tags="workbenchCrafting" craft_tool="toolAmmoPress">
					<ingredient name="ammo556mmHIpower" count="10"/>
				</recipe>
			
				<recipe name="ammoDismantle556mmArmorPiercing" count="1" craft_area="workbench" tags="workbenchCrafting" craft_tool="toolAmmoPress">
					<ingredient name="ammo556mmArmorPiercing" count="10"/>
				</recipe>
			</append>
			
			<remove xpath="/recipes/recipe[@name='IZYgunT1LRLongRifleM16a1']"/>
			
			<set xpath="/recipes/recipe[@name='ammo556mmBulletBallBundle']/@tags">learnable,workbenchCrafting</set>
			<set xpath="/recipes/recipe[@name='ammo556mmHIpowerBundle']/@tags">learnable,workbenchCrafting</set>
			<set xpath="/recipes/recipe[@name='ammo556mmArmorPiercingBundle']/@tags">learnable,workbenchCrafting</set>
			
			<setattribute xpath="/recipes/recipe[@name='ammo556mmBulletBall']" name="craft_tool">toolAmmoPress</setattribute>
			<setattribute xpath="/recipes/recipe[@name='ammo556mmHIpower']" name="craft_tool">toolAmmoPress</setattribute>
			<setattribute xpath="/recipes/recipe[@name='ammo556mmArmorPiercing']" name="craft_tool">toolAmmoPress</setattribute>
		</if>
	</conditional>
	
	<!-- *** Q600 rework -->
	<set xpath="/recipes/recipe[starts-with(@name,'IZY')]/effect_group/passive_effect[@name='CraftingIngredientCount' and @level='2,6']/@level">101,600</set>
	<set xpath="/recipes/recipe[starts-with(@name,'IZY')]/effect_group/passive_effect[@name='CraftingIngredientCount' and @level='6']/@level">501,600</set>
	
</HellsJanitor>